# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

DB_NAME=comanda_digital
DB_USER=root
DB_PASSWORD=root

# Gere um valor seguro com: openssl rand -base64 64
JWT_SECRET=
# Tempo de expiração do token em milissegundos (padrão: 8h)
JWT_EXPIRATION=28800000

CORS_ALLOWED_ORIGINS=http://localhost:4200
